unit FormProdutos;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls;

type
  TTelaCadProdutos = class(TForm)
    EditDescProd: TEdit;
    LabelDescProd: TLabel;
    LabelPrecoProd: TLabel;
    LabelUnMedProd: TLabel;
    EditPrecoProd: TEdit;
    EditUnMedProd: TEdit;
    ButtonSalvarProd: TButton;
    ButtonFecharProd: TButton;
    procedure ButtonSalvarProdClick(Sender: TObject);
    procedure ButtonFecharProdClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  TelaCadProdutos: TTelaCadProdutos;

implementation

{$R *.dfm}

procedure TTelaCadProdutos.ButtonFecharProdClick(Sender: TObject);
begin
  Close;
end;

procedure TTelaCadProdutos.ButtonSalvarProdClick(Sender: TObject);
begin
  if EditDescProd.Text = '' then
  begin
    ShowMessage('Informe o nome do Produto');
    EditDescProd.SetFocus;
    Exit;
  end;

  if EditPrecoProd.Text = '' then
  begin
    ShowMessage('Informe o Preþo de Venda');
    EditPrecoProd.SetFocus;
    Exit;
  end;

  if EditUnMedProd.Text = '' then
  begin
    ShowMessage('Informe a Unidade de medida');
    EditUnMedProd.SetFocus;
    Exit;
  end;

  FDQuery1.SQL.Clear;
  FDQuery1.SQL.Add('INSERT INTO CLIENTES (NOME, DOCUMENTO, CIDADE)');
  FDQuery1.SQL.Add('VALUES (:NOME, :DOCUMENTO, :CIDADE)');

  FDQuery1.ParamByName('NOME').AsString := EditDescProd.Text;
  FDQuery1.ParamByName('DOCUMENTO').AsString := EditPrecoProd.Text;
  FDQuery1.ParamByName('CIDADE').AsString := EditUnMedProd.Text;

  FDQuery1.ExecSQL;

  ShowMessage('Cliente salvo!');

  EditDescProd.Text := '';
  EditPrecoProd.Text := '';
  EditUnMedProd.Text := '';
  EditDescProd.SetFocus;
end;

end.
